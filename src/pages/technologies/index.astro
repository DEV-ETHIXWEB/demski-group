    <h2>Technologies We Utilize</h2>
    <div class="tech-logos-grid">
      <div class="tech-logo-item"><img src="https://demskigroup.com/wp-content/uploads/2024/05/net.png" alt=".NET" /></div>
      <div class="tech-logo-item"><img src="https://demskigroup.com/wp-content/uploads/2024/05/java.png" alt="Java" /></div>
      <div class="tech-logo-item"><img src="https://demskigroup.com/wp-content/uploads/2024/07/kotlin.png" alt="Kotlin" /></div>
      <div class="tech-logo-item"><img src="https://demskigroup.com/wp-content/uploads/2024/07/PHP.png" alt="PHP" /></div>
      <div class="tech-logo-item"><img src="https://demskigroup.com/wp-content/uploads/2024/05/react.png" alt="React" /></div>
      <div class="tech-logo-item"><img src="https://demskigroup.com/wp-content/uploads/2024/05/Layer-2.png" alt="Swift" /></div>
      <div class="tech-logo-item"><img src="https://demskigroup.com/wp-content/uploads/2024/05/Python-Logo.png" alt="Python" /></div>
      <div class="tech-logo-item"><img src="https://demskigroup.com/wp-content/uploads/2024/05/go.png" alt="Go" /></div>
      <div class="tech-logo-item"><img src="https://demskigroup.com/wp-content/uploads/2024/05/nodejs.png" alt="Node.js" /></div>
      <div class="tech-logo-item"><img src="https://demskigroup.com/wp-content/uploads/2024/07/Javascript.png" alt="JavaScript" /></div>
      <div class="tech-logo-item"><img src="https://demskigroup.com/wp-content/uploads/2024/07/c-1.png" alt="C++" /></div>
      <div class="tech-logo-item"><img src="https://demskigroup.com/wp-content/uploads/2024/07/c.png" alt="C#" /></div>
