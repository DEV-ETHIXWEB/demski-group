      <div class="tech-logo-item"><img src="https://demskigroup.com/wp-content/uploads/2024/07/angular.png" alt="Angular" /></div>
    </div>
  </section>

  <!-- CODE THE FUTURE -->
  <section class="tech-code-future">
    <div class="tech-code-future-top">
      <h2>Code the Future: Innovative Solutions, Tailored for You</h2>
      <a href="/services/" class="tech-see-all-btn">See all services →</a>
    </div>
    <div class="services-grid">
      <div class="service-card">
        <div class="service-card-icon">⌨</div>
        <h3>Custom Software Development</h3>
        <p>Develop tailored software solutions to meet your unique business needs and drive operational efficiency.</p>
      </div>
      <div class="service-card">
        <div class="service-card-icon">✓</div>
        <h3>QA and Testing</h3>
        <p>Ensure your software is reliable, secure, and performs flawlessly under all conditions with our comprehensive QA and testing services.</p>
      </div>
      <div class="service-card">
