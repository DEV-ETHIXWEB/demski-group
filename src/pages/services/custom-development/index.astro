    <div class="cd-why__inner">
      <div class="cd-why__left">
        <h2>Why Choose Us</h2>
        <img src="https://demskigroup.com/wp-content/uploads/2024/05/software-engineers-working-on-project-and-programm-2023-11-27-04-52-32-utc-1-1024x570.jpg" alt="software engineers working on project" />
