  function initInfiniteSlider(sliderId, prevId, nextId) {
    const slider = document.getElementById(sliderId);
    const btnPrev = document.getElementById(prevId);
    const btnNext = document.getElementById(nextId);
    if (!slider || !btnPrev || !btnNext) return;

    const cards = Array.from(slider.querySelectorAll('.about-post-card'));
    if (!cards.length) return;
    const gap = parseInt(getComputedStyle(slider).gap) || 20;

    cards.forEach(card => {
      const clone = card.cloneNode(true);
      clone.setAttribute('aria-hidden', 'true');
      slider.appendChild(clone);
    });
    cards.slice().reverse().forEach(card => {
      const clone = card.cloneNode(true);
      clone.setAttribute('aria-hidden', 'true');
      slider.prepend(clone);
    });

    function cardWidth() {
      return slider.querySelector('.about-post-card').offsetWidth + gap;
    }

    slider.scrollLeft = cardWidth() * cards.length;

    let busy = false;

    function next() {
      if (busy) return;
      busy = true;
      slider.scrollBy({ left: cardWidth(), behavior: 'smooth' });
      setTimeout(() => {
        if (slider.scrollLeft >= cardWidth() * cards.length * 2) {
          slider.scrollLeft = cardWidth() * cards.length;
        }
        busy = false;
      }, 450);
    }

    function prev() {
      if (busy) return;
      busy = true;
      slider.scrollBy({ left: -cardWidth(), behavior: 'smooth' });
      setTimeout(() => {
        if (slider.scrollLeft <= cardWidth() * (cards.length - 1)) {
          slider.scrollLeft = cardWidth() * cards.length * 2 - cardWidth();
        }
        busy = false;
      }, 450);
    }

    btnNext.addEventListener('click', next);
    btnPrev.addEventListener('click', prev);
  }

  initInfiniteSlider('about-blog-slider', 'about-blog-prev', 'about-blog-next');
})();
</script>

</Layout>
