/* review cards animation */
@keyframes cardSlideDown {
  from { opacity: 0; transform: translateY(-40px); }
  to   { opacity: 1; transform: translateY(0); }
}
.rc {
  opacity: 0;
  animation: cardSlideDown 0.6s ease forwards;
}
/* cards 1-2 together */
.reviews-grid .rc:nth-child(1),
.reviews-grid .rc:nth-child(2)  { animation-delay: 0.1s; }
/* cards 3-4 together */
.reviews-grid .rc:nth-child(3),
.reviews-grid .rc:nth-child(4)  { animation-delay: 0.4s; }
/* cards 5-6 together */
.reviews-grid .rc:nth-child(5),
.reviews-grid .rc:nth-child(6)  { animation-delay: 0.7s; }
/* cards 7-8 together */
.reviews-grid .rc:nth-child(7),
.reviews-grid .rc:nth-child(8)  { animation-delay: 1.0s; }
/* cards 9-10 together */
.reviews-grid .rc:nth-child(9),
.reviews-grid .rc:nth-child(10) { animation-delay: 1.3s; }
/* cards 11-12 together */
.reviews-grid .rc:nth-child(11),
.reviews-grid .rc:nth-child(12) { animation-delay: 1.6s; }
/* cards 13-14 together */
.reviews-grid .rc:nth-child(13),
.reviews-grid .rc:nth-child(14) { animation-delay: 1.9s; }
/* cards 15-16 together */
.reviews-grid .rc:nth-child(15),
.reviews-grid .rc:nth-child(16) { animation-delay: 2.2s; }

/* review cards grid */
